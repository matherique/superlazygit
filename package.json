{
  "name": "superlayzgit",
  "version": "0.1.0",
  "private": true,
  "description": "Electron app para visualizar branches, commits e diffs de um repositório Git local.",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "start": "electron dist-electron/main/main.js"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-syntax-highlighter": "^15.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
